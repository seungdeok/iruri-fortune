{
  "name": "iruri-fortune",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": "10.33.2"
  },
  "scripts": {
    "dev": "granite dev",
    "dev:local": "node node_modules/@apps-in-toss/web-framework/bin.js dev",
    "build": "ait build",
    "deploy": "ait deploy",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "lefthook install"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,cjs,json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@apps-in-toss/web-framework": "^2.10.4",
    "@emotion/react": "^11.0.0",
    "@toss/tds-colors": "latest",
    "@toss/tds-mobile": "latest",
    "@toss/tds-mobile-ait": "latest",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "lefthook": "^2.1.9",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
}
